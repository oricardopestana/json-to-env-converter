---

---

<div class="flex flex-col h-full w-full">
    <label for="env-output" class="text-sm font-semibold mb-2" style="color: var(--text-secondary);"> Output </label>

    <div class="relative flex-1">
        <textarea
            id="env-output"
            readonly
            placeholder="Converted output will appear here..."
            spellcheck="false"
            class="w-full h-full rounded-lg border-2 p-4 font-mono text-sm leading-relaxed outline-none transition-colors duration-200 resize-none"
            style="background: var(--bg-input); border-color: var(--border); color: var(--text-primary); --placeholder-color: var(--placeholder);"
        ></textarea>
    </div>

    <div class="mt-2 flex items-center justify-between min-h-6">
        <div
            id="env-status"
            class="flex items-center gap-2 text-sm transition-opacity duration-200 opacity-0"
            aria-live="polite"
        >
            <span id="env-status-icon"></span>
            <span id="env-status-message"></span>
        </div>

        <button
            id="env-copy-btn"
            type="button"
            class="hidden items-center gap-1.5 rounded-md px-3 py-1 text-xs font-medium transition-colors duration-150 focus:outline-none focus:ring-2"
            style="background: var(--bg-input); color: var(--text-primary); --focus-ring: var(--focus-ring);"
            aria-label="Copy to clipboard"
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path d="M8 3a1 1 0 011-1h2a1 1 0 110 2H9a1 1 0 01-1-1z"></path>
                <path d="M6 3a2 2 0 00-2 2v11a2 2 0 002 2h8a2 2 0 002-2V5a2 2 0 00-2-2 3 3 0 01-3 3H9a3 3 0 01-3-3z"
                ></path>
            </svg>
            <span id="env-copy-label">Copy</span>
        </button>
    </div>
</div>

<style>
    textarea::placeholder {
        color: var(--placeholder-color);
    }
    textarea:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px var(--focus-ring);
    }
    #env-copy-btn:hover {
        background: var(--border) !important;
        color: var(--text-primary) !important;
        opacity: 0.9;
    }
    #env-copy-btn:focus {
        box-shadow: 0 0 0 3px var(--focus-ring);
    }
</style>

<script>
    const envTextarea = document.getElementById("env-output") as HTMLTextAreaElement;
    const statusContainer = document.getElementById("env-status") as HTMLDivElement;
    const statusIcon = document.getElementById("env-status-icon") as HTMLSpanElement;
    const statusMessage = document.getElementById("env-status-message") as HTMLSpanElement;
    const copyBtn = document.getElementById("env-copy-btn") as HTMLButtonElement;
    const copyLabel = document.getElementById("env-copy-label") as HTMLSpanElement;

    function showOutputStatus(message: string, keyCount: number) {
        statusContainer.classList.remove("opacity-0");
        statusContainer.classList.add("opacity-100");
        statusIcon.textContent = "✓";
        statusIcon.style.color = "var(--valid-text)";
        statusMessage.textContent = message;
        statusMessage.style.color = "var(--valid-text)";

        if (keyCount > 0) {
            copyBtn.classList.remove("hidden");
            copyBtn.classList.add("flex");
        }
    }

    function showOutputError(message: string) {
        statusContainer.classList.remove("opacity-0");
        statusContainer.classList.add("opacity-100");
        statusIcon.textContent = "✗";
        statusIcon.style.color = "var(--invalid-text)";
        statusMessage.textContent = message;
        statusMessage.style.color = "var(--invalid-text)";

        copyBtn.classList.remove("flex");
        copyBtn.classList.add("hidden");
    }

    function clearOutputStatus() {
        statusContainer.classList.remove("opacity-100");
        statusContainer.classList.add("opacity-0");
        statusIcon.textContent = "";
        statusIcon.style.color = "";
        statusMessage.textContent = "";
        statusMessage.style.color = "";

        copyBtn.classList.remove("flex");
        copyBtn.classList.add("hidden");
    }

    document.addEventListener("output-generated", ((e: CustomEvent) => {
        const { outputText, keyCount, outputFormat } = e.detail;
        envTextarea.value = outputText;

        if (keyCount > 0) {
            const formatLabel = outputFormat === "json" ? "JSON" : "env";
            showOutputStatus(`Generated ${formatLabel} — ${keyCount} variable${keyCount !== 1 ? "s" : ""}`, keyCount);
        } else {
            envTextarea.value = "";
            clearOutputStatus();
        }
    }) as EventListener);

    document.addEventListener("output-error", ((e: CustomEvent) => {
        envTextarea.value = "";
        if (e.detail.message) {
            showOutputError(e.detail.message);
        } else {
            clearOutputStatus();
        }
    }) as EventListener);

    // Copy to clipboard
    copyBtn.addEventListener("click", async () => {
        const text = envTextarea.value;
        if (!text) return;

        try {
            await navigator.clipboard.writeText(text);
            copyLabel.textContent = "Copied!";
            copyBtn.style.background = "var(--valid-bg)";
            copyBtn.style.color = "var(--valid-text)";

            setTimeout(() => {
                copyLabel.textContent = "Copy";
                copyBtn.style.background = "";
                copyBtn.style.color = "";
            }, 2000);
        } catch {
            copyLabel.textContent = "Failed";
            setTimeout(() => {
                copyLabel.textContent = "Copy";
            }, 2000);
        }
    });
</script>
