---

---

<div class="flex flex-col h-full w-full">
    <label for="json-input" class="text-sm font-semibold mb-2" style="color: var(--text-secondary);"> Input </label>

    <div class="relative flex-1">
        <textarea
            id="json-input"
            placeholder="Paste JSON or env format here..."
            spellcheck="false"
            class="w-full h-full rounded-lg border-2 pt-4 pr-4 pb-4 pl-12 font-mono text-sm leading-relaxed outline-none transition-colors duration-200 resize-none overflow-x-auto whitespace-pre"
            style="background: var(--bg-input); border-color: var(--border); color: var(--text-primary); --placeholder-color: var(--placeholder);"
        ></textarea>
        <div id="json-input-line-numbers"
             class="absolute left-0 top-0 bottom-0 w-10 overflow-hidden select-none pointer-events-none text-right pr-2 z-10 font-mono text-sm leading-relaxed pt-4 pb-4 rounded-l-lg"
             style="background: var(--bg-input); color: var(--text-muted); border-right: 1px solid var(--border);"></div>
    </div>

    <div
        id="json-status"
        class="mt-2 flex items-center gap-2 text-sm min-h-6 transition-opacity duration-200 opacity-0"
        aria-live="polite"
    >
        <span id="json-status-icon"></span>
        <span id="json-status-message"></span>
    </div>
</div>

<style>
    textarea::placeholder {
        color: var(--placeholder-color);
    }
    textarea:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px var(--focus-ring);
    }
    textarea:focus ~ #json-input-line-numbers {
        border-right-color: #3b82f6;
    }
</style>

<script>
    const textarea = document.getElementById("json-input") as HTMLTextAreaElement;
    const lineNumbers = document.getElementById("json-input-line-numbers") as HTMLDivElement;
    const statusContainer = document.getElementById("json-status") as HTMLDivElement;
    const statusIcon = document.getElementById("json-status-icon") as HTMLSpanElement;
    const statusMessage = document.getElementById("json-status-message") as HTMLSpanElement;

    let debounceTimer: ReturnType<typeof setTimeout> | null = null;
    const DEBOUNCE_DELAY = 600;

    function updateLineNumbers() {
        const lineCount = (textarea.value || "").split("\n").length;
        let html = "";
        for (let i = 1; i <= lineCount; i++) {
            html += `<div>${i}</div>`;
        }
        lineNumbers.innerHTML = html;
    }

    textarea.addEventListener("scroll", () => {
        lineNumbers.scrollTop = textarea.scrollTop;
    });

    updateLineNumbers();

    function setValid(message: string) {
        textarea.style.borderColor = "var(--valid-border)";
        textarea.style.boxShadow = "0 0 0 3px var(--valid-bg)";

        statusContainer.classList.remove("opacity-0");
        statusContainer.classList.add("opacity-100");
        statusIcon.textContent = "✓";
        statusIcon.style.color = "var(--valid-text)";
        statusMessage.textContent = message;
        statusMessage.style.color = "var(--valid-text)";
    }

    function setInvalid(message: string) {
        textarea.style.borderColor = "var(--invalid-border)";
        textarea.style.boxShadow = "0 0 0 3px var(--invalid-bg)";

        statusContainer.classList.remove("opacity-0");
        statusContainer.classList.add("opacity-100");
        statusIcon.textContent = "✗";
        statusIcon.style.color = "var(--invalid-text)";
        statusMessage.textContent = message;
        statusMessage.style.color = "var(--invalid-text)";
    }

    function clearStatus() {
        textarea.style.borderColor = "";
        textarea.style.boxShadow = "";

        statusContainer.classList.remove("opacity-100");
        statusContainer.classList.add("opacity-0");
        statusIcon.textContent = "";
        statusIcon.style.color = "";
        statusMessage.textContent = "";
        statusMessage.style.color = "";
    }

    function parseEnvValue(raw: string): string {
        const trimmed = raw.trim();
        if (trimmed.startsWith('"') && trimmed.endsWith('"')) {
            return trimmed
                .slice(1, -1)
                .replace(/\\"/g, '"')
                .replace(/\\\\/g, "\\");
        }
        return trimmed;
    }

    function parseEnvLine(line: string): { key: string; value: string } | null {
        const trimmed = line.trim();
        if (!trimmed || trimmed.startsWith("#")) return null;

        const eqIndex = trimmed.indexOf("=");
        if (eqIndex === -1) return null;

        const key = trimmed.slice(0, eqIndex).trim();
        const value = trimmed.slice(eqIndex + 1);

        if (!key) return null;

        return { key, value: parseEnvValue(value) };
    }

    function isEnvFormat(raw: string): boolean {
        const lines = raw.split("\n");
        let foundValidLine = false;

        for (const line of lines) {
            const result = parseEnvLine(line);
            if (result !== null) {
                foundValidLine = true;
            } else {
                const trimmed = line.trim();
                if (trimmed && !trimmed.startsWith("#")) {
                    return false;
                }
            }
        }

        return foundValidLine;
    }

    function positionToLineCol(raw: string, position: number): { line: number; col: number } {
        let line = 1;
        let col = 1;
        for (let i = 0; i < position && i < raw.length; i++) {
            if (raw[i] === "\n") {
                line++;
                col = 1;
            } else {
                col++;
            }
        }
        return { line, col };
    }

    function extractJsonError(err: unknown, raw: string): { message: string; position: number | null } {
        if (!(err instanceof SyntaxError)) {
            return { message: "Unknown parsing error", position: null };
        }

        let position: number | null = null;
        const posMatch = err.message.match(/at position (\d+)/);
        if (posMatch) {
            position = parseInt(posMatch[1], 10);
        }

        if (position === null) {
            const chars = ["{", "}", "[", "]", ","];
            for (let i = 0; i < raw.length; i++) {
                if (chars.includes(raw[i])) {
                    let depth = 0;
                    let lastNonWS = "";
                    for (let j = 0; j < i; j++) {
                        const c = raw[j];
                        if (c === "{" || c === "[") depth++;
                        else if (c === "}" || c === "]") depth--;
                        if (c.trim()) lastNonWS = c;
                    }
                    if (depth < 0 || (raw[i] !== "," && (lastNonWS === "," || lastNonWS === "{" || lastNonWS === "[" || lastNonWS === ":"))) {
                        position = i;
                        break;
                    }
                }
            }
        }

        if (position === null) {
            return { message: err.message.replace(/^JSON\.parse:\s*/, ""), position: null };
        }

        const { line, col } = positionToLineCol(raw, position);
        let cleanMessage = err.message.replace(/^JSON\.parse:\s*/, "");
        cleanMessage = cleanMessage.replace(/\s*at position \d+(\s*\(.*\))?\s*$/, "");
        cleanMessage = cleanMessage.replace(/, "["\d[\s\S]*?"\s*is not valid JSON$/, "");

        return {
            message: `line ${line}, col ${col}: ${cleanMessage}`,
            position,
        };
    }

    function highlightErrorPosition(position: number | null) {
        if (position === null || position < 0 || position >= textarea.value.length) return;

        textarea.setSelectionRange(position, position + 1);
        const lineHeight = parseFloat(getComputedStyle(textarea).lineHeight) || 20;
        textarea.scrollTop = Math.max(0, (positionToLineCol(textarea.value, position).line - 3) * lineHeight);
        textarea.focus();
    }

    function formatAndValidate(source: "paste" | "input") {
        const raw = textarea.value.trim();

        if (!raw) {
            clearStatus();
            textarea.dispatchEvent(new CustomEvent("input-invalid", { bubbles: true }));
            return;
        }

        const startsWithBrace = raw.startsWith("{") || raw.startsWith("[");

        if (startsWithBrace) {
            try {
                const parsed = JSON.parse(raw);

                if (typeof parsed !== "object" || parsed === null || Array.isArray(parsed)) {
                    setInvalid("JSON must be an object (key-value pairs), not an array or primitive.");
                    textarea.dispatchEvent(new CustomEvent("input-invalid", { bubbles: true }));
                    return;
                }

                const formatted = JSON.stringify(parsed, null, 2);
                const cursorWasAtEnd = textarea.selectionStart === textarea.value.length;

                textarea.value = formatted;
                updateLineNumbers();

                if (cursorWasAtEnd) {
                    textarea.selectionStart = textarea.value.length;
                    textarea.selectionEnd = textarea.value.length;
                }

                const keyCount = Object.keys(parsed).length;
                setValid(`Detected JSON — ${keyCount} key${keyCount !== 1 ? "s" : ""}`);

                textarea.dispatchEvent(
                    new CustomEvent("input-validated", {
                        bubbles: true,
                        detail: { format: "json", raw: formatted },
                    }),
                );
            } catch (err) {
                const { message, position } = extractJsonError(err, raw);
                setInvalid(`Invalid JSON — ${message}`);
                highlightErrorPosition(position);
                textarea.dispatchEvent(new CustomEvent("input-invalid", { bubbles: true }));
            }
        } else if (isEnvFormat(raw)) {
            const lines = raw.split("\n").filter((line) => {
                const trimmed = line.trim();
                return trimmed && !trimmed.startsWith("#");
            });

            setValid(`Detected env format — ${lines.length} variable${lines.length !== 1 ? "s" : ""}`);

            textarea.dispatchEvent(
                new CustomEvent("input-validated", {
                    bubbles: true,
                    detail: { format: "env", raw },
                }),
            );
        } else {
            setInvalid("Could not detect format. Expected JSON object or KEY=VALUE lines.");
            textarea.dispatchEvent(new CustomEvent("input-invalid", { bubbles: true }));
        }
    }

    // Handle paste: intercept and format immediately
    textarea.addEventListener("paste", (e: ClipboardEvent) => {
        e.preventDefault();

        const pastedText = e.clipboardData?.getData("text/plain") ?? "";

        const start = textarea.selectionStart;
        const end = textarea.selectionEnd;
        const before = textarea.value.slice(0, start);
        const after = textarea.value.slice(end);

        textarea.value = before + pastedText + after;
        textarea.selectionStart = start + pastedText.length;
        textarea.selectionEnd = start + pastedText.length;
        updateLineNumbers();

        if (debounceTimer) {
            clearTimeout(debounceTimer);
            debounceTimer = null;
        }

        formatAndValidate("paste");
    });

    // Handle typing: debounced format + validate
    textarea.addEventListener("input", () => {
        updateLineNumbers();
        if (debounceTimer) {
            clearTimeout(debounceTimer);
        }

        debounceTimer = setTimeout(() => {
            formatAndValidate("input");
        }, DEBOUNCE_DELAY);
    });

    // Also validate on blur for good measure
    textarea.addEventListener("blur", () => {
        if (debounceTimer) {
            clearTimeout(debounceTimer);
            debounceTimer = null;
        }

        if (textarea.value.trim()) {
            formatAndValidate("input");
        }
    });
</script>
