<script>
    function flattenToEnv(obj: Record<string, unknown>, prefix: string = ""): Map<string, string> {
        const result = new Map<string, string>();

        for (const [key, value] of Object.entries(obj)) {
            const envKey = prefix ? `${prefix}_${key}` : key;
            const upperKey = envKey.toUpperCase();

            if (value === null || value === undefined) {
                result.set(upperKey, "");
            } else if (Array.isArray(value)) {
                const allPrimitive = value.every((item) => typeof item !== "object" || item === null);
                if (allPrimitive) {
                    result.set(upperKey, value.map(String).join(","));
                } else {
                    result.set(upperKey, JSON.stringify(value));
                }
            } else if (typeof value === "object") {
                const nested = flattenToEnv(value as Record<string, unknown>, envKey);
                for (const [nestedKey, nestedValue] of nested) {
                    result.set(nestedKey, nestedValue);
                }
            } else {
                const strValue = String(value);
                if (strValue === "" || /[\s#=\\"]/.test(strValue)) {
                    result.set(upperKey, `"${strValue.replace(/\\/g, "\\\\").replace(/"/g, '\\"')}"`);
                } else {
                    result.set(upperKey, strValue);
                }
            }
        }

        return result;
    }

    function parseEnvValue(raw: string): string {
        const trimmed = raw.trim();
        if (trimmed.startsWith('"') && trimmed.endsWith('"')) {
            return trimmed
                .slice(1, -1)
                .replace(/\\"/g, '"')
                .replace(/\\\\/g, "\\");
        }
        return trimmed;
    }

    function parseEnvToJson(raw: string): Record<string, string> | null {
        const result: Record<string, string> = {};
        const lines = raw.split("\n");
        let foundValidLine = false;

        for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed || trimmed.startsWith("#")) continue;

            const eqIndex = trimmed.indexOf("=");
            if (eqIndex === -1) return null;

            const key = trimmed.slice(0, eqIndex).trim();
            const value = trimmed.slice(eqIndex + 1);

            if (!key) return null;

            result[key] = parseEnvValue(value);
            foundValidLine = true;
        }

        return foundValidLine ? result : null;
    }

    function detectFormat(raw: string): "json" | "env" | null {
        const trimmed = raw.trim();
        if (!trimmed) return null;

        if (trimmed.startsWith("{") || trimmed.startsWith("[")) {
            try {
                const parsed = JSON.parse(trimmed);
                if (typeof parsed === "object" && parsed !== null && !Array.isArray(parsed)) {
                    return "json";
                }
            } catch {
                // Not valid JSON, fall through
            }
        }

        const envResult = parseEnvToJson(trimmed);
        if (envResult !== null) {
            return "env";
        }

        if (trimmed.startsWith("{") || trimmed.startsWith("[")) {
            try {
                JSON.parse(trimmed);
                return "json";
            } catch {
                return null;
            }
        }

        return null;
    }

    function convertJsonToEnv(raw: string): { text: string; count: number } | string {
        try {
            const parsed = JSON.parse(raw);

            if (typeof parsed !== "object" || parsed === null || Array.isArray(parsed)) {
                return "JSON must be an object with key-value pairs";
            }

            const envMap = flattenToEnv(parsed);
            const lines: string[] = [];

            for (const [key, value] of envMap) {
                lines.push(`${key}=${value}`);
            }

            return { text: lines.join("\n"), count: envMap.size };
        } catch (err) {
            return err instanceof SyntaxError
                ? err.message.replace(/^JSON\.parse:\s*/, "")
                : "Unknown parsing error";
        }
    }

    function convertEnvToJson(raw: string): { text: string; count: number } | string {
        const parsed = parseEnvToJson(raw);
        if (parsed === null) {
            return "Invalid env format: each line must be KEY=VALUE";
        }

        const keys = Object.keys(parsed);
        if (keys.length === 0) {
            return "No valid env variables found";
        }

        return { text: JSON.stringify(parsed, null, 2), count: keys.length };
    }

    function emitOutput(text: string, keyCount: number, format: string) {
        document.dispatchEvent(
            new CustomEvent("output-generated", { detail: { outputText: text, keyCount, outputFormat: format } }),
        );
    }

    function emitError(message: string) {
        document.dispatchEvent(new CustomEvent("output-error", { detail: { message } }));
    }

    document.addEventListener("input-validated", ((e: CustomEvent) => {
        const { format, raw } = e.detail;
        const inputEl = document.getElementById("json-input") as HTMLTextAreaElement | null;

        if (!inputEl) {
            emitError("Input not found");
            return;
        }

        const inputRaw = raw ?? inputEl.value.trim();

        if (!inputRaw) {
            emitError("");
            return;
        }

        if (format === "json") {
            const result = convertJsonToEnv(inputRaw);
            if (typeof result === "string") {
                emitError(result);
            } else {
                emitOutput(result.text, result.count, "env");
            }
        } else if (format === "env") {
            const result = convertEnvToJson(inputRaw);
            if (typeof result === "string") {
                emitError(result);
            } else {
                emitOutput(result.text, result.count, "json");
            }
        } else {
            emitError("");
        }
    }) as EventListener);

    document.addEventListener("input-invalid", () => {
        emitError("");
    });
</script>
