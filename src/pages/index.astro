---
import InputTextArea from "../components/InputTextArea.astro";
import ControlPanel from "../components/ControlPanel.astro";
import OutputTextArea from "../components/OutputTextArea.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
    <div class="flex flex-col h-screen" style="background: var(--bg-page);">
        <header class="px-6 pt-6 pb-2 text-center">
            <h1 class="text-2xl font-bold" style="color: var(--text-primary);">JSON ↔ ENV Converter</h1>
            <p class="mt-1 text-sm" style="color: var(--text-muted);">Paste JSON or ENV format to convert between the two</p>
        </header>

        <div class="flex items-stretch flex-1 gap-4 px-6 pb-6">
        <div class="flex-1 min-w-0 rounded-lg p-6 flex flex-col" style="background: var(--bg-card); box-shadow: 0 4px 6px -1px var(--shadow), 0 2px 4px -2px var(--shadow);">
            <InputTextArea />
        </div>
        <ControlPanel />
        <div class="flex-1 min-w-0 rounded-lg p-6 flex flex-col" style="background: var(--bg-card); box-shadow: 0 4px 6px -1px var(--shadow), 0 2px 4px -2px var(--shadow);">
            <OutputTextArea />
        </div>
    </div>
    </div>
</Layout>
