---
import InputTextArea from "../components/InputTextArea.astro";
import ControlPanel from "../components/ControlPanel.astro";
import OutputTextArea from "../components/OutputTextArea.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout>
    <div class="flex flex-col h-screen" style="background: var(--bg-page);">
        <header class="relative px-6 pt-6 pb-2 text-center">
            <h1 class="text-2xl font-bold" style="color: var(--text-primary);">JSON ↔ ENV Converter</h1>
            <p class="mt-1 text-sm" style="color: var(--text-muted);">
                Paste JSON or ENV format to convert between the two, IN YOUR BROWSER, with no API calls (you can check!)
            </p>
            <a
                href="https://github.com/oricardopestana/json-to-env-converter"
                target="_blank"
                rel="noopener noreferrer"
                class="absolute top-6 right-6 hover:opacity-70 transition-opacity"
                aria-label="View source on GitHub"
            >
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" style="color: var(--text-muted);">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                </svg>
            </a>
        </header>

        <div class="flex items-stretch flex-1 gap-4 px-6 pb-6">
            <div
                class="flex-1 min-w-0 rounded-lg p-6 flex flex-col"
                style="background: var(--bg-card); box-shadow: 0 4px 6px -1px var(--shadow), 0 2px 4px -2px var(--shadow);"
            >
                <InputTextArea />
            </div>
            <ControlPanel />
            <div
                class="flex-1 min-w-0 rounded-lg p-6 flex flex-col"
                style="background: var(--bg-card); box-shadow: 0 4px 6px -1px var(--shadow), 0 2px 4px -2px var(--shadow);"
            >
                <OutputTextArea />
            </div>
        </div>
    </div>
</Layout>
